NEXT_PUBLIC_INSTANT_APP_ID=
INSTANTDB_ADMIN_TOKEN=
PRODE_SESSION_SECRET=

# Admin bootstrap (se crea/actualiza automaticamente al iniciar)
PRODE_ADMIN_EMAIL=
PRODE_ADMIN_PASSWORD=
PRODE_ADMIN_FIRST_NAME=Admin
PRODE_ADMIN_LAST_NAME=PRODE
PRODE_ADMIN_PHONE=

APP_BASE_URL=http://localhost:3000
APP_BASE_URL_LOCAL=http://localhost:3000
APP_BASE_URL_PROD=https://tu-dominio.com
# URL publica para webhook de Talo (en local usa ngrok/cloudflared)
TALOPAY_WEBHOOK_BASE_URL=
TALOPAY_WEBHOOK_BASE_URL_LOCAL=
TALOPAY_WEBHOOK_BASE_URL_PROD=

# TaloPay
TALOPAY_API_BASE=https://api.talo.com.ar
TALOPAY_API_BASE_LOCAL=https://sandbox-api.talo.com.ar
TALOPAY_API_BASE_PROD=https://api.talo.com.ar
TALOPAY_USER_ID=
TALOPAY_USER_ID_LOCAL=
TALOPAY_USER_ID_PROD=
TALOPAY_CLIENT_ID=
TALOPAY_CLIENT_ID_LOCAL=
TALOPAY_CLIENT_ID_PROD=
TALOPAY_CLIENT_SECRET=
TALOPAY_CLIENT_SECRET_LOCAL=
TALOPAY_CLIENT_SECRET_PROD=
TALOPAY_REGISTRATION_AMOUNT_ARS=100
TALOPAY_REGISTRATION_AMOUNT_ARS_LOCAL=100
TALOPAY_REGISTRATION_AMOUNT_ARS_PROD=100
TALOPAY_CURRENCY_ID=ARS
TALOPAY_CURRENCY_ID_LOCAL=ARS
TALOPAY_CURRENCY_ID_PROD=ARS
TALOPAY_REGISTRATION_TITLE=Inscripcion PRODE Fase Grupos Mundial 2026
TALOPAY_REGISTRATION_TITLE_LOCAL=Inscripcion PRODE Fase Grupos Mundial 2026
TALOPAY_REGISTRATION_TITLE_PROD=Inscripcion PRODE Fase Grupos Mundial 2026

# Seguridad webhook (recomendado)
TALOPAY_WEBHOOK_SECRET=

# Edge security (middleware)
# Paises permitidos (ISO 3166-1 alpha-2), por defecto solo AR.
ALLOWED_COUNTRIES=AR
# Si true, bloquea requests donde no se puede inferir el pais.
BLOCK_UNKNOWN_COUNTRY=true
# Si true, bloquea user-agents automatizados comunes.
BLOCK_BOTS=true

# Solo activar si necesitas permitir eval() en scripts (reduce seguridad CSP).
CSP_ALLOW_UNSAFE_EVAL=false
